# Copia este archivo como .env y llena los valores reales

SECRET_KEY=django-insecure-cambia-esto-por-una-clave-segura
DEBUG=True

# Base de datos — deja False para usar SQLite en desarrollo
USE_POSTGRES=False
DB_NAME=examplanner
DB_USER=postgres
DB_PASSWORD=tu_password
DB_HOST=localhost
DB_PORT=5432

# Canvas — obtener en: Configuración de Canvas > Desarrollador > Nuevo cliente OAuth
CANVAS_BASE_URL=https://tecsup.instructure.com
CANVAS_CLIENT_ID=tu_client_id_aqui
CANVAS_CLIENT_SECRET=tu_client_secret_aqui
CANVAS_REDIRECT_URI=http://localhost:8000/api/canvas/callback/
